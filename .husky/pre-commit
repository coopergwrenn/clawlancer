#!/usr/bin/env sh
# Pre-commit hook: when vm-manifest.ts is staged, automatically refresh
# a timestamped touch comment in EVERY cron route that imports VM_MANIFEST.
# This invalidates Vercel's @vercel/nft trace cache for those bundles so
# the next deploy picks up the new manifest content.
#
# Background: Vercel's nft trace cache silently serves stale vm-manifest.ts
# imports to bundled cron routes across deploys. The manual touch-comment
# habit (commits 5e710334, 16aa97c9) catches this reactively, but only
# when the developer remembers. This hook mechanizes the habit.
#
# This is layer 2 of the defense; layer 3 is lib/manifest-integrity.ts
# (runtime hash compare against GitHub raw). Both together = belt + braces.
#
# Sister design note: we ONLY touch route.ts when vm-manifest.ts is in the
# staged diff. Touching unconditionally would create churn on unrelated
# commits. The shape `git diff --cached --name-only` returns staged paths
# relative to repo root.
#
# 2026-05-24 (v120 commit incident): extended to file-drift route.
# The v120 commit only touched reconcile-fleet's bundle, leaving file-drift
# with stale v119 manifest → manifest-integrity flagged stale_bundle and
# refused to run → strip-thinking patch never reached vm-1019. Any new
# cron route that imports VM_MANIFEST must be added to ROUTE_FILES below.

# Detect staged changes to vm-manifest.ts
if git diff --cached --name-only | grep -q "instaclaw/lib/vm-manifest.ts"; then
  # Every cron route that imports VM_MANIFEST goes here. To find candidates:
  #   grep -lRn "from \"@/lib/vm-manifest\"" instaclaw/app/api/cron/
  ROUTE_FILES="
instaclaw/app/api/cron/reconcile-fleet/route.ts
instaclaw/app/api/cron/file-drift/route.ts
"

  TS=$(date -u +"%Y-%m-%d %H:%M UTC")
  COMMENT="// nft cache-bust auto-touch (vm-manifest.ts changed): $TS"

  for ROUTE_FILE in $ROUTE_FILES; do
    if [ ! -f "$ROUTE_FILE" ]; then
      echo "[pre-commit] WARN: $ROUTE_FILE not found — skipping nft cache-bust touch"
      continue
    fi

    # Each route has its own stable single-line anchor near the top. Match
    # the first one we find; bail with a warning if none present.
    #   reconcile-fleet: const CONFIG_AUDIT_BATCH_SIZE = ...
    #   file-drift:      const CRON_NAME = "file-drift";
    ANCHOR=""
    if grep -q "^const CONFIG_AUDIT_BATCH_SIZE" "$ROUTE_FILE"; then
      ANCHOR="^const CONFIG_AUDIT_BATCH_SIZE"
    elif grep -q "^const CRON_NAME = " "$ROUTE_FILE"; then
      ANCHOR="^const CRON_NAME = "
    fi

    if [ -z "$ANCHOR" ]; then
      echo "[pre-commit] WARN: no known anchor in $ROUTE_FILE — skipping cache-bust (manual touch recommended)"
      continue
    fi

    if [ "$(uname)" = "Darwin" ]; then
      sed -i '' "/$ANCHOR/a\\
$COMMENT
" "$ROUTE_FILE"
    else
      sed -i "/$ANCHOR/a\\$COMMENT" "$ROUTE_FILE"
    fi
    git add "$ROUTE_FILE"
    echo "[pre-commit] vm-manifest.ts changed → auto-touched $ROUTE_FILE for nft cache-bust"
  done
fi
