{
  "name": "@instaclaw/dispatch",
  "version": "0.5.1",
  "description": "Let your InstaClaw AI agent control your computer — screenshots, clicks, typing, and more via a secure WebSocket relay",
  "bin": {
    "instaclaw-dispatch": "./dist/index.js"
  },
  "type": "module",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js"
  },
  "keywords": [
    "instaclaw",
    "ai-agent",
    "computer-use",
    "remote-control",
    "dispatch",
    "usecomputer"
  ],
  "repository": {
    "type": "git",
