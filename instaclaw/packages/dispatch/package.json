    "directory": "instaclaw/packages/dispatch"
  },
  "homepage": "https://instaclaw.io",
  "dependencies": {
    "chalk": "^5.6.2",
    "inquirer": "^9.3.8",
    "sharp": "^0.33.0",
    "usecomputer": "^0.1.4",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
