+import { checkpoint } from './checkpoint-operation.ts';
 
 // --- Types ---
 
@@ -3141,6 +3144,8 @@ export const operations: Operation[] = [
   add_timeline_entry, get_timeline,
   // Admin
   get_stats, get_health, run_doctor, get_versions, revert_version,
+  // instaclaw patch: pg_control flush — see CLAUDE.md Rule 54.
+  checkpoint,
   // v0.31.1 (Issue #734): thin-client banner identity packet (read-scope, banner-only)
   get_brain_identity,
